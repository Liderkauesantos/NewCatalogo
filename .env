# ============================================================
# Variáveis de ambiente para o Docker Compose
# Copie este arquivo para .env no mesmo nível do docker-compose.yml
# e preencha os valores reais.
# ============================================================

# Senha do superusuário PostgreSQL
POSTGRES_PASSWORD=0mXTJS+xbGZFWRjrGGu/56jlwiHsMm9zjvNA6PWNQd4=

# Senha da role authenticator (PostgREST → PostgreSQL)
AUTHENTICATOR_PASSWORD=VS3xHTiOPx4Pva7NlkvPshMoQg8IFadAszQtmrMrhmE=

# JWT secret (mínimo 32 caracteres)
# Gerar com: openssl rand -base64 32
JWT_SECRET=YW00An8Hx8uUiYDTb4+2l7muIjruc0AZU9+rZJ1qMqQ=

# ============================================================
# Cloudinary (upload de imagens)
# Crie uma conta gratuita em: https://cloudinary.com
# ============================================================

# Seu Cloud Name (encontra no Dashboard do Cloudinary)
VITE_CLOUDINARY_CLOUD_NAME=ddv1lmcha
CLOUDINARY_CLOUD_NAME=ddv1lmcha

# API Key e API Secret (para signed upload - mais seguro)
# Encontra em: Settings → Access Keys
CLOUDINARY_API_KEY=921399435441289
CLOUDINARY_API_SECRET=u2Dh9EVUG6ElpmWhlSmwF_aa9qA

# Upload Preset (para unsigned upload - fallback)
# Crie em: Settings → Upload → Upload Presets → Add Upload Preset → Signing Mode: Unsigned
VITE_CLOUDINARY_UPLOAD_PRESET=newcatalogo

# URL do serviço de assinatura (desenvolvimento: http://localhost:3001)
VITE_CLOUDINARY_SIGNATURE_URL=http://localhost:3001
